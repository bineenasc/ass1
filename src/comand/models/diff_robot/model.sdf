<?xml version="1.0"?>
<sdf version='1.11'>
  <model name='dx_bot'>

    <link name='footprint'>
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.0141</ixx>
          <iyy>0.0104</iyy>
          <izz>0.0154</izz>
        </inertia>
      </inertial>

      <collision name='base_collision'>
        <pose>0 0 0.069 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.1</length>
            <radius>0.15</radius>
          </cylinder>
        </geometry>
      </collision>

      <visual name='base_visual'>
        <pose>0 0 0.069 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.1</length>
            <radius>0.15</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>1 1 0 1</diffuse>
        </material>
      </visual>
    </link>

    <link name='link_wheel_1'>
      <pose>0 0.15 0.04 0 1.5708 1.5708</pose> <inertial>
        <mass>0.1</mass>
      </inertial>
      <collision name='wheel1_collision'>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name='wheel1_visual'>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name='joint_wheel_1' type='revolute'>
      <parent>footprint</parent>
      <child>link_wheel_1</child>
      <axis>
        <xyz>0 1 0</xyz> 
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>100</effort>
          <velocity>100</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name='link_wheel_2'>
      <pose>0 -0.15 0.04 0 1.5708 1.5708</pose>
      <inertial>
        <mass>0.1</mass>
      </inertial>
      <collision name='wheel2_collision'>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name='wheel2_visual'>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name='joint_wheel_2' type='revolute'>
      <parent>footprint</parent>
      <child>link_wheel_2</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>100</effort>
          <velocity>100</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link_laser">
      <pose>0 0 0.134 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>1e-4</ixx>
          <iyy>1e-4</iyy>
          <izz>1e-4</izz>
        </inertia>
      </inertial>
      <collision name="laser_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="laser_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>

      <sensor name="hokuyo_lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <update_rate>10</update_rate>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <min_angle>-3.1416</min_angle>
              <max_angle>3.1416</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>10.0</max>
          </range>
        </lidar>
        <topic>/scan</topic>
      </sensor>
    </link>

    <joint name="joint_laser" type="fixed">
      <parent>footprint</parent>
      <child>link_laser</child>
    </joint>

    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>joint_wheel_1</left_joint>
      <right_joint>joint_wheel_2</right_joint>
      <wheel_separation>0.3</wheel_separation>
      <wheel_radius>0.04</wheel_radius>
      <topic>/cmd_vel</topic>
    </plugin>

  </model>
</sdf>