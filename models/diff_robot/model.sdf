<?xml version="1.0"?>
<sdf version='1.11'>
  <model name='dx_bot'>

    <!-- BASE LINK -->
    <link name='footprint'>
      <pose>0 0 0 0 0 0</pose>

      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.0141</ixx>
          <iyy>0.0104</iyy>
          <izz>0.0154</izz>
        </inertia>
      </inertial>

      <!-- BODY -->
      <collision name='base_collision'>
        <pose>0 0 0.069 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.1</length>
            <radius>0.15</radius>
          </cylinder>
        </geometry>
      </collision>

      <visual name='base_visual'>
        <pose>0 0 0.069 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>0.1</length>
            <radius>0.15</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>1 1 0 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- LEFT WHEEL -->
    <link name='link_wheel_1'>
      <pose>-0.15 0 0.039 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
      </inertial>

      <collision name='wheel1_collision'>
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name='wheel1_visual'>
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name='joint_wheel_1' type='continuous'>
      <parent>footprint</parent>
      <child>link_wheel_1</child>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
    </joint>

    <!-- RIGHT WHEEL -->
    <link name='link_wheel_2'>
      <pose>0.15 0 0.039 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
      </inertial>

      <collision name='wheel2_collision'>
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name='wheel2_visual'>
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name='joint_wheel_2' type='continuous'>
      <parent>footprint</parent>
      <child>link_wheel_2</child>
      <axis>
        <xyz>1 0 0</xyz>
      </axis>
    </joint>

    <!-- LIDAR LINK -->
    <link name="link_laser">
      <pose>0 0 0.18 0 0 0</pose>

      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>1e-4</ixx>
          <iyy>1e-4</iyy>
          <izz>1e-4</izz>
        </inertia>
      </inertial>

      <collision name="laser_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="laser_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>

      <!-- HOKUYO LIDAR -->
      <sensor name="hokuyo_lidar" type="lidar">
        <pose>0 0 0 0 0 0</pose>
        <update_rate>40</update_rate>
        <always_on>1</always_on>
        <visualize>true</visualize>

        <lidar>
          <scan>
            <horizontal>
              <samples>1080</samples>
              <resolution>1</resolution>
              <min_angle>-2.35619</min_angle>
              <max_angle>2.35619</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>30.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>

        <topic>scan</topic>
      </sensor>
    </link>

    <joint name="joint_laser" type="fixed">
      <parent>footprint</parent>
      <child>link_laser</child>
      <pose>0 0 0.18 0 0 0</pose>
    </joint>

  </model>
</sdf>